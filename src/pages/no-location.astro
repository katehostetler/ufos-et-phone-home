---
import PageLayout from "@/layouts/PageLayout.astro";
import RecordCard from "@/components/RecordCard.astro";
import GalleryFilter from "@/components/GalleryFilter.astro";
import records from "@/data/records.json";
import type { Record } from "@/types/record";

const noLoc = (records as Record[])
  .filter((r) => !r.hasLocation)
  .sort((a, b) => (b.year ?? 0) - (a.year ?? 0));

const counts = {
  vid: noLoc.filter((r) => r.mediaType === "vid").length,
  img: noLoc.filter((r) => r.mediaType === "img").length,
  pdf: noLoc.filter((r) => r.mediaType === "pdf").length,
};
---

<PageLayout
  title="LOCATION UNKNOWN"
  subtitle={`${noLoc.length} records the files give no incident location for — they can't be pinned to the globe · mostly Cold War FBI files`}
>
  <GalleryFilter mode="inline" counts={counts} />
  <div class="grid">
    {noLoc.map((r) => <RecordCard record={r} />)}
  </div>
</PageLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 18px;
  }
  @media (max-width: 767px) {
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 12px;
    }
  }
</style>
