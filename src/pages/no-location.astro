---
import PageLayout from "@/layouts/PageLayout.astro";
import RecordCard from "@/components/RecordCard.astro";
import records from "@/data/records.json";
import type { Record } from "@/types/record";

const noLoc = (records as Record[])
  .filter((r) => !r.hasLocation)
  .sort((a, b) => (b.year ?? 0) - (a.year ?? 0));
---

<PageLayout
  title="LOCATION UNKNOWN"
  subtitle={`${noLoc.length} records without an incident location · mostly Cold War FBI files`}
>
  <div class="grid">
    {noLoc.map((r) => <RecordCard record={r} />)}
  </div>
</PageLayout>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 18px;
  }
  @media (max-width: 767px) {
    .grid {
      grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
      gap: 12px;
    }
  }
</style>
