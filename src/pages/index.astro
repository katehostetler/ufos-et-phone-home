---
import Base from "@/layouts/Base.astro";
import Hud from "@/components/Hud.astro";
import Ticker from "@/components/Ticker.astro";
import GlobeApp from "@/components/GlobeApp";
import HallOfFameOverlay from "@/components/HallOfFameOverlay";
// (Legend removed — pin colors are self-evident; counts now live in the dock chips' tooltips)
import records from "@/data/records.json";
import featuredRaw from "@/data/featured.json";
import { resolveFeatured } from "@/lib/featured";
import type { Record } from "@/types/record";

const all = records as Record[];
const counts = {
  vid: all.filter((r) => r.mediaType === "vid").length,
  img: all.filter((r) => r.mediaType === "img").length,
  pdf: all.filter((r) => r.mediaType === "pdf").length,
  unmapped: all.filter((r) => !r.hasLocation).length,
};

const featured = resolveFeatured(featuredRaw as any, all);
---

<Base>
  <Hud />

  <main class="globe-page">
    <Ticker total={all.length} />

    <GlobeApp client:only="react" records={all} />

    <HallOfFameOverlay client:only="react" featured={featured} />

    <!-- ★ HALL OF FAME chip — bottom-left, above the dock -->
    <button type="button" class="chip hof-chip" data-open="hall-of-fame" title="The wildest files in the release"><span class="hof-star">★</span> HALL OF FAME</button>

    <!-- ⓘ ABOUT chip — bottom-right corner (icon-only on mobile) -->
    <a href="/about" class="chip info-chip" title="About this archive" aria-label="About this archive"><span class="info-glyph">i</span><span class="info-text"> ABOUT</span></a>

    <footer class="dock">
      <a href="/gallery" class="dock-label" title={`Browse the full archive (${all.length} records)`}>
        <span class="dl-icon">▦</span><span class="dl-text">BROWSE GALLERY</span>
      </a>
      <a href="/videos" data-queue="vid" class="chip vid active chip-icon" title={`Browse all ${counts.vid} videos`} aria-label={`Browse all ${counts.vid} videos`}>
        <span class="chip-glyph">▶</span>
      </a>
      <a href="/photos" data-queue="img" class="chip img active chip-icon" title={`Browse all ${counts.img} photos`} aria-label={`Browse all ${counts.img} photos`}>
        <span class="chip-glyph">⊡</span>
      </a>
      <a href="/files" data-queue="pdf" class="chip pdf active chip-icon" title={`Browse all ${counts.pdf} documents`} aria-label={`Browse all ${counts.pdf} documents`}>
        <span class="chip-glyph">▤</span>
      </a>
    </footer>

    <div class="banner-instr banner-pointer">DRAG TO ROTATE · SCROLL TO ZOOM · CLICK PINS</div>
    <div class="banner-instr banner-touch">DRAG TO ROTATE · PINCH TO ZOOM · TAP PINS</div>
  </main>
</Base>

<script>
  // On the homepage, dock chips open the in-place queue browser instead of
  // navigating away. They still degrade to the gallery page if JS is off.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;

    // Queue chips (dock)
    const queueTrigger = target?.closest?.("[data-queue]") as HTMLElement | null;
    if (queueTrigger) {
      const type = queueTrigger.dataset.queue;
      if (type) {
        e.preventDefault();
        window.dispatchEvent(new CustomEvent("open-queue", { detail: type }));
      }
      return;
    }

    // Hall of Fame chip
    const hofTrigger = target?.closest?.("[data-open='hall-of-fame']") as HTMLElement | null;
    if (hofTrigger) {
      e.preventDefault();
      window.dispatchEvent(new CustomEvent("open-hall-of-fame"));
    }
  });
</script>

<style>
  .globe-page {
    position: fixed;
    top: 56px; left: 0; right: 0; bottom: 56px;
  }

  /* the filterbar lives inside the React island and floats over the globe */
  :global(.filterbar) {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    z-index: 6;
    background: rgba(0,0,0,.45);
    backdrop-filter: blur(6px);
    padding: 6px 10px 6px 12px;
    border: 1px solid var(--color-line);
    border-radius: 2px;
  }
  :global(.filterbar-label) {
    font-size: 9px;
    letter-spacing: .22em;
    color: var(--color-hud);
    padding-right: 8px;
    border-right: 1px solid rgba(106,255,200,.25);
    margin-right: 2px;
    flex-shrink: 0;
  }

  :global(.globe-stage) {
    position: absolute; inset: 0;
    z-index: 1;
  }
  /* Keep the rendered globe bright & punchy. The city-light toning (dimmer, less
     "pin gold") and the deep-navy ocean floor are done in the shader, not here,
     so the overall image stays as bright as before. */
  :global(.globe-stage canvas) {
    filter: brightness(1.16) contrast(1.05) saturate(1.03);
  }

  /* dock at bottom — opens the in-place gallery/queue browser */
  .dock {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: rgba(0,0,0,.5);
    border-top: 1px solid var(--color-line);
    backdrop-filter: blur(8px);
    z-index: 7;
  }
  .dock .chip { text-decoration: none; padding: 7px 16px; }
  /* "▦ BROWSE GALLERY" — a link to /gallery (the full unfiltered archive). */
  .dock-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 9px;
    letter-spacing: .18em;
    line-height: 1;
    white-space: nowrap;
    color: var(--color-hud);
    padding-right: 12px;
    margin-right: 2px;
    border-right: 1px solid rgba(106,255,200,.25);
    flex-shrink: 0;
    text-decoration: none;
    transition: text-shadow .15s;
  }
  .dock-label .dl-icon { font-size: 19px; line-height: 1; }
  .dock-label:hover { text-shadow: 0 0 10px var(--color-hud); }

  /* Show the pointer/touch banner appropriate to the device. */
  .banner-touch { display: none; }
  @media (hover: none) and (pointer: coarse) {
    .banner-pointer { display: none; }
    .banner-touch { display: inline-flex; }
  }

  .banner-instr {
    position: absolute;
    bottom: 76px;
    left: 50%;
    transform: translateX(-50%);
    background: rgba(8,12,20,.8);
    backdrop-filter: blur(8px);
    border: 1px solid var(--color-line);
    padding: 7px 14px;
    font-size: 10px;
    letter-spacing: .15em;
    color: rgba(106,255,200,.85);
    z-index: 6;
    border-radius: 2px;
    text-transform: uppercase;
    pointer-events: none;
    animation: hud-fade 8s 5s forwards;
  }
  @keyframes hud-fade {
    to { opacity: 0; }
  }

  /* ---------- TABLET ---------- */
  @media (max-width: 1024px) {
    :global(.filterbar) {
      top: 64px;
      gap: 6px;
      padding: 5px 6px;
    }
    .dock { gap: 8px; }
    .dock .chip { padding: 6px 12px; }
    .banner-instr {
      bottom: 70px;
      font-size: 9px;
      padding: 6px 12px;
    }
  }

  /* ---------- MOBILE ---------- */
  @media (max-width: 767px) {
    .globe-page {
      top: 48px;
      bottom: 52px;
    }

    /* Filterbar — raised up close under the DECLASSIFIED stamp so it isn't
       sitting in the middle of the globe; tight enough that all 3 type chips
       fit across a 390px screen without horizontal scrolling. */
    :global(.filterbar) {
      top: 28px;
      left: 6px;
      right: 6px;
      transform: none;
      justify-content: center;
      gap: 4px;
      padding: 4px 6px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      white-space: nowrap;
    }
    :global(.filterbar)::-webkit-scrollbar { display: none; }
    :global(.filterbar) .chip {
      flex: 0 0 auto;
      padding: 4px 6px;
      font-size: 8px;
      letter-spacing: .03em;
      gap: 4px;
    }
    :global(.filterbar) .chip .swatch { width: 5px; height: 5px; }
    :global(.filterbar-label) {
      font-size: 7.5px;
      letter-spacing: .12em;
      padding-right: 6px;
    }
    /* Dock — sized so the LOCATION UNKNOWN chip fits without horizontal scroll */
    .dock {
      height: 52px;
      gap: 5px;
      justify-content: center;
      padding: 0 6px;
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      white-space: nowrap;
    }
    .dock::-webkit-scrollbar { display: none; }
    .dock .chip {
      flex: 0 0 auto;
      padding: 6px 8px;
      font-size: 8.5px;
      letter-spacing: .08em;
    }
    .dock .chip-icon { padding: 4px 9px; }
    .dock .chip-icon .chip-glyph { font-size: 18px; }
    .dock-label { font-size: 8px; letter-spacing: .1em; padding-right: 8px; margin-right: 0; gap: 6px; }
    .dock-label .dl-icon { font-size: 17px; }

    .banner-instr {
      bottom: 64px;
      font-size: 8.5px;
      padding: 5px 10px;
      letter-spacing: .12em;
      white-space: nowrap;
    }
  }
</style>
