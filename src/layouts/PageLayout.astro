---
import Base from "@/layouts/Base.astro";
import Hud from "@/components/Hud.astro";
import records from "@/data/records.json";

interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<Base title={`${title} — UFOs / ET Phone Home`}>
  <Hud recordCount={records.length} />

  <main class="page">
    <header class="page-head">
      <h1 class="page-title">{title}</h1>
      {subtitle && <p class="page-subtitle">{subtitle}</p>}
    </header>
    <div class="page-body">
      <slot />
    </div>
  </main>
</Base>

<style>
  .page {
    padding: 88px 32px 64px;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .page-head {
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 16px;
    margin-bottom: 28px;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: .05em;
    margin: 0;
    color: var(--color-hud);
    text-shadow: 0 0 16px rgba(106,255,200,.3);
  }
  .page-subtitle {
    margin: 8px 0 0;
    font-size: 11px;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
  }

  @media (max-width: 1024px) {
    .page { padding: 76px 22px 48px; }
    .page-title { font-size: 22px; }
  }

  @media (max-width: 767px) {
    .page {
      padding: 64px 16px 40px;
    }
    .page-head {
      padding-bottom: 12px;
      margin-bottom: 20px;
    }
    .page-title {
      font-size: 18px;
      letter-spacing: .04em;
    }
    .page-subtitle {
      font-size: 10px;
      letter-spacing: .12em;
    }
  }
</style>
