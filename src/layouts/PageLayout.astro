---
import Base from "@/layouts/Base.astro";
import Hud from "@/components/Hud.astro";
import GalleryModalRoot from "@/components/GalleryModalRoot";
import records from "@/data/records.json";
import type { Record } from "@/types/record";

interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
const allRecords = records as Record[];
---

<Base title={`${title} — UFOs / ET Phone Home`}>
  <Hud />

  <main class="page">
    <header class="page-head">
      <a href="/" class="back-to-globe" aria-label="Back to globe">
        <span class="btg-arrow">←</span>
        <span class="btg-label">BACK TO GLOBE</span>
      </a>
      <h1 class="page-title">{title}</h1>
      {subtitle && <p class="page-subtitle">{subtitle}</p>}
    </header>
    <div class="page-body">
      <slot />
    </div>
  </main>

  <GalleryModalRoot client:load records={allRecords} />
</Base>

<script>
  // Click-delegation: any [data-record-id] element opens the record modal in-place
  // by dispatching a `record-modal-open` event that GalleryModalRoot listens for.
  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    const trigger = target?.closest?.("[data-record-id]") as HTMLElement | null;
    if (!trigger) return;
    const id = trigger.dataset.recordId;
    if (!id) return;
    e.preventDefault();
    window.dispatchEvent(new CustomEvent("record-modal-open", { detail: id }));
  });
</script>

<style>
  .page {
    padding: 88px 32px 64px;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }
  .page-head {
    border-bottom: 1px solid var(--color-line);
    padding-bottom: 16px;
    margin-bottom: 28px;
  }
  .back-to-globe {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .2em;
    color: var(--color-hud);
    text-decoration: none;
    padding: 6px 12px;
    border: 1px solid rgba(106,255,200,.35);
    border-radius: 2px;
    background: rgba(106,255,200,.06);
    transition: all .15s;
  }
  .back-to-globe:hover {
    background: rgba(106,255,200,.16);
    border-color: var(--color-hud);
  }
  .btg-arrow { font-size: 14px; line-height: 1; }
  .btg-label { font-weight: 700; }
  .page-title {
    font-family: var(--font-display);
    font-size: 26px;
    font-weight: 700;
    letter-spacing: .05em;
    margin: 0;
    color: var(--color-hud);
    text-shadow: 0 0 16px rgba(106,255,200,.3);
  }
  .page-subtitle {
    margin: 8px 0 0;
    font-size: 11px;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: rgba(255,255,255,.55);
  }

  @media (max-width: 1024px) {
    .page { padding: 76px 22px 48px; }
    .page-title { font-size: 22px; }
  }

  @media (max-width: 767px) {
    .page {
      padding: 64px 16px 40px;
    }
    .page-head {
      padding-bottom: 12px;
      margin-bottom: 20px;
    }
    .page-title {
      font-size: 18px;
      letter-spacing: .04em;
    }
    .page-subtitle {
      font-size: 10px;
      letter-spacing: .12em;
    }
  }
</style>
