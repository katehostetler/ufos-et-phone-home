---
// (no props — record count lives in the Ticker on the right side of the globe)
---

<header class="top">
  <a href="/" class="brand">
    <span class="logo">UFOS</span>
    <span class="logo-sub">/ ET PHONE HOME</span>
  </a>
  <span class="clock" id="clock">UTC --:--:--</span>
  <nav class="primary-nav" aria-label="Site nav">
    <a href="/about" class="nav-about"><span class="nav-glyph">ⓘ</span>ABOUT</a>
  </nav>
  <span class="stamp">DECLASSIFIED · RELEASE_01</span>
</header>

<style>
  .top {
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 56px;
    display: flex;
    align-items: center;
    padding: 0 28px;
    background: linear-gradient(180deg, rgba(0,0,0,.6) 0%, rgba(0,0,0,0) 100%);
    border-bottom: 1px solid var(--color-line);
    gap: 18px;
    backdrop-filter: blur(4px);
    z-index: 7;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 10px;
    text-decoration: none;
  }
  /* "UFOS" stays the HUD green; "/ ET PHONE HOME" glows purple. */
  .logo {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 18px;
    letter-spacing: .24em;
    color: #b8ffe0;
    text-shadow:
      0 0 8px rgba(106,255,200,.9),
      0 0 18px rgba(106,255,200,.55),
      0 0 36px rgba(106,255,200,.3);
  }
  .logo-sub {
    font-size: 12px;
    letter-spacing: .3em;
    color: #e0c8ff;
    text-shadow:
      0 0 8px rgba(199,148,255,.9),
      0 0 18px rgba(168,99,255,.6),
      0 0 34px rgba(140,80,255,.35);
  }
  .clock {
    font-size: 10px;
    letter-spacing: .15em;
    opacity: .65;
    margin-left: 8px;
    font-variant-numeric: tabular-nums;
    color: #cdd3dc;
  }
  .primary-nav {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-left: auto;
  }
  .nav-label {
    font-size: 9px;
    letter-spacing: .25em;
    color: rgba(106,255,200,.55);
    padding-right: 4px;
    border-right: 1px solid rgba(106,255,200,.2);
    text-transform: uppercase;
  }
  .primary-nav a {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 10px;
    letter-spacing: .2em;
    color: rgba(232,237,243,.6);
    text-decoration: none;
    transition: color .15s;
  }
  .primary-nav a:hover { color: var(--color-hud); }
  .nav-glyph {
    font-size: 11px;
    color: rgba(106,255,200,.7);
    line-height: 1;
    letter-spacing: 0;
  }
  .primary-nav a:hover .nav-glyph { color: var(--color-hud); }
  .stamp {
    font-size: 9px;
    letter-spacing: .2em;
    color: var(--color-vid);
    border: 1px solid rgba(255,59,59,.55);
    padding: 4px 10px;
    border-radius: 2px;
    background: rgba(255,59,59,.06);
    text-transform: uppercase;
    font-weight: 700;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .top {
      gap: 12px;
      padding: 0 20px;
    }
    .logo-sub { font-size: 10px; letter-spacing: .25em; }
    .clock { margin-left: 0; }
    .primary-nav { gap: 10px; }
    .nav-label { display: none; }
    .stamp { font-size: 8px; padding: 3px 7px; letter-spacing: .15em; }
  }

  /* Mobile — show glyphs only, hide text labels */
  @media (max-width: 767px) {
    .top {
      height: 48px;
      padding: 0 10px 0 26px;
      gap: 6px;
    }
    .brand { gap: 6px; flex-shrink: 1; min-width: 0; }
    .logo { font-size: 13px; letter-spacing: .2em; }
    .logo-sub { font-size: 9px; letter-spacing: .22em; }
    .clock { display: none; }
    .stamp { display: none; }
    .nav-label { display: none; }
    .primary-nav {
      gap: 14px;
      margin-left: auto;
    }
    .primary-nav a {
      font-size: 0;
      letter-spacing: 0;
      gap: 0;
    }
    .nav-glyph {
      font-size: 14px;
      color: rgba(106,255,200,.85);
    }
  }

  /* Very small mobile — keep glyphs visible */
  @media (max-width: 480px) {
    .top {
      padding: 0 10px 0 28px;
      gap: 6px;
    }
    .primary-nav { gap: 11px; }
    .nav-glyph { font-size: 13px; }
  }
</style>

<script>
  function tick() {
    const el = document.getElementById('clock');
    if (!el) return;
    el.textContent = `UTC ${new Date().toISOString().slice(11, 19)}`;
  }
  tick();
  setInterval(tick, 1000);
</script>
